#!/usr/bin/env bash
# Recursively discover Git object databases and deeply garbage-collect them in parallel.

# shellcheck disable=SC2317

set -uo pipefail

usage() {
	cat <<'USAGE'
Usage: git-deep-gc [-j JOBS] [--prune-now] [DIRECTORY ...]

Recursively find Git repositories and run in parallel:
  git gc --aggressive

Linked worktrees are deduplicated by their shared Git object database.
Symlinked child directories are not followed.

Options:
  -j JOBS     Maximum parallel GC jobs (default: min(CPU count, 4))
  --prune-now Also remove unreachable objects immediately; stop Git writers first
  -h          Show this help
USAGE
}

resolve_common_dir() {
	local candidate="$1"
	local common_dir

	common_dir="$(git -C "${candidate}" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" || return 1
	(cd -P -- "${common_dir}" && pwd)
}

run_gc() {
	local common_dir="$1"
	local prune_now="$2"
	local gc_args=(--aggressive)
	local gc_pid=''

	forward_signal() {
		if [[ -n "${gc_pid}" ]]; then
			kill -TERM "${gc_pid}" 2>/dev/null || true
		fi
	}
	trap forward_signal HUP INT TERM

	if [[ "${prune_now}" == true ]]; then
		gc_args+=(--prune=now)
	fi

	printf '[git-deep-gc] START %s\n' "${common_dir}"
	git --git-dir="${common_dir}" gc "${gc_args[@]}" >/dev/null 2>&1 &
	gc_pid="$!"
	if wait "${gc_pid}"; then
		trap - HUP INT TERM
		printf '[git-deep-gc] DONE  %s\n' "${common_dir}"
		return 0
	fi

	trap - HUP INT TERM
	printf '[git-deep-gc] FAIL  %s\n' "${common_dir}" >&2
	return 1
}

cpu_count="$(nproc)"
if ((cpu_count > 4)); then
	jobs=4
else
	jobs="${cpu_count}"
fi

directories=()
prune_now=false
while (($# > 0)); do
	case "$1" in
	-j)
		if (($# < 2)); then
			printf 'Error: -j requires a positive integer\n' >&2
			exit 2
		fi
		jobs="$2"
		shift 2
		;;
	-h | --help)
		usage
		exit 0
		;;
	--prune-now)
		prune_now=true
		shift
		;;
	--)
		shift
		directories+=("$@")
		break
		;;
	-*)
		printf 'Error: unsupported option: %s\n' "$1" >&2
		exit 2
		;;
	*)
		directories+=("$1")
		shift
		;;
	esac
done

if [[ ! "${jobs}" =~ ^[1-9][0-9]*$ ]]; then
	printf 'Error: JOBS must be a positive integer\n' >&2
	exit 2
fi

if ((${#directories[@]} == 0)); then
	directories=(.)
fi

scan_directories=()
for directory in "${directories[@]}"; do
	scan_directory=''
	if [[ ! -d "${directory}" ]]; then
		printf 'Error: directory does not exist: %s\n' "${directory}" >&2
		exit 2
	fi

	if ! scan_directory="$(cd -P -- "${directory}" && pwd)"; then
		printf 'Error: cannot access directory: %s\n' "${directory}" >&2
		exit 2
	fi

	scan_directories+=("${scan_directory}")
done

if ! markers_file="$(mktemp)"; then
	printf 'Error: could not create temporary scan file\n' >&2
	exit 1
fi

pids=()
cleanup() {
	rm -f -- "${markers_file}"
}

trap cleanup EXIT

terminate_children() {
	local exit_code="$1"
	local pid

	trap - HUP INT TERM
	if ((${#pids[@]} > 0)); then
		kill -TERM "${pids[@]}" 2>/dev/null || true
		for pid in "${pids[@]}"; do
			wait "${pid}" 2>/dev/null || true
		done
	fi

	exit "${exit_code}"
}

trap 'terminate_children 129' HUP
trap 'terminate_children 130' INT
trap 'terminate_children 143' TERM

scan_failed=0
if ! find "${scan_directories[@]}" \
	\( -name .git -print0 -prune \) -o \
	\( -type d -name '*.git' -print0 -prune \) -o \
	\( -type f -name config -print0 \) \
	>"${markers_file}"; then
	printf '[git-deep-gc] Scan completed with errors\n' >&2
	scan_failed=1
fi

declare -A seen=()
repositories=()

for directory in "${scan_directories[@]}"; do
	if common_dir="$(resolve_common_dir "${directory}")" && [[ -z "${seen["${common_dir}"]:-}" ]]; then
		seen["${common_dir}"]=1
		repositories+=("${common_dir}")
	fi
done

while IFS= read -r -d '' marker; do
	case "$(basename -- "${marker}")" in
	.git)
		if [[ -d "${marker}" && "$(git -C "${marker}" rev-parse --is-bare-repository 2>/dev/null)" == true ]]; then
			candidate="${marker}"
		else
			candidate="$(dirname -- "${marker}")"
		fi
		;;
	config)
		candidate="$(dirname -- "${marker}")"
		[[ -f "${candidate}/HEAD" && -d "${candidate}/objects" ]] || continue
		[[ "$(git -C "${candidate}" rev-parse --is-bare-repository 2>/dev/null)" == true ]] || continue
		;;
	*)
		candidate="${marker}"
		;;
	esac

	if common_dir="$(resolve_common_dir "${candidate}")" && [[ -z "${seen["${common_dir}"]:-}" ]]; then
		seen["${common_dir}"]=1
		repositories+=("${common_dir}")
	fi
done <"${markers_file}"

if ((${#repositories[@]} == 0)); then
	printf '[git-deep-gc] No Git repositories found\n'
	exit "${scan_failed}"
fi

printf '[git-deep-gc] Found %d object databases; jobs=%d\n' "${#repositories[@]}" "${jobs}"

failed="${scan_failed}"
pids=()

wait_for_one() {
	local completed_pid
	local pid
	local remaining_pids=()

	if ! wait -n -p completed_pid "${pids[@]}"; then
		failed=1
	fi

	for pid in "${pids[@]}"; do
		if [[ "${pid}" != "${completed_pid}" ]]; then
			remaining_pids+=("${pid}")
		fi
	done

	pids=("${remaining_pids[@]}")
}

for common_dir in "${repositories[@]}"; do
	run_gc "${common_dir}" "${prune_now}" &
	pids+=("$!")

	if ((${#pids[@]} >= jobs)); then
		wait_for_one
	fi
done

while ((${#pids[@]} > 0)); do
	wait_for_one
done

exit "${failed}"
